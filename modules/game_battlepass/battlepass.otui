ProgressPanel < Panel
  anchors.fill: parent
  ScrollablePanel
    id: missionsBackground
    height: 386
    image-source: /images/ui/1pixel-down-frame
    image-border: 1
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right
    horizontal-scrollbar: progressPanelScrollBar
    padding: 1
