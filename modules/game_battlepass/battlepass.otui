    inverted-view: true
    Panel
      id: progressPanelContent
      size: 29400 384
      anchors.top: parent.top
      anchors.left: parent.left
      @onSetup: |
        for i = 0, 76 do
          local widget = g_ui.createWidget('MapFragment', self)
          widget:setImageSource("/images/game/battlepass/map/battlepass-background_" .. math.min(i, 46))
          widget:setMarginLeft(384 * i)
        end

    UICreature
      id: playerOutfit
      focusable: false
      phantom: true
      size: 64 64
      anchors.top: parent.top
      anchors.left: parent.left
      idle-animate: true
      margin-left: 165
      margin-top: 165

  HorizontalScrollBar
    id: progressPanelScrollBar
    anchors.bottom: prev.bottom
    anchors.right: prev.right
    anchors.left: prev.left
    step: 100
    margin: 0 1 1 1
    pixels-scroll: true
    visible: true
    phantom: true
    inverted-view: true

BattlePassShopInfoPanel < Panel
  size: 105 20
  image-source: /images/ui/infoPanel
  image-border: 2

  UIWidget
    id: panelIcon
    size: 11 11
    anchors.verticalCenter: parent.verticalCenter
    anchors.right: parent.right
    margin-right: 2
    image-source: /images/game/task_hunt/task-tokens
    phantom: true

  Label
    id: panelLabel
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: panelIcon.left
    anchors.bottom: parent.bottom
    margin-right: 2
    font: $var-cip-main-font
    color: $var-text-cip-color
    text-align: right
    text: 0

BattlePassTabButton < UIButton
  height: 33
  image-source: /images/ui/2pixel_up_frame_borderimage
  image-border: 30
  font: $var-cip-main-font
  color: $var-text-cip-color
  phantom: false

  $checked:
    image-source: /images/ui/2pixel-up-frame-borderimage-upside-down

  UIWidget
    id: tabIcon
    size: 32 32
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: parent.left
    margin-left: 10
    phantom: true

  Label
    id: tabLabel
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    text-align: center
    font: $var-cip-main-font
    color: $var-text-cip-color
    phantom: true

BattlePassShopCard < Window
  draggable: false
  size: 295 144
  image-border: 30
  phantom: false
  focusable: true
  text: ""
  padding-top: 25
  padding-left: 10
  padding-right: 0
  padding-bottom: 4

  Panel
    id: previewPanel
    size: 66 66
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 0
    margin-left: 0
    image-source: /images/ui/item66
    image-border: 2

    UICreature
      id: creaturePreview
      size: 64 64
      anchors.centerIn: parent
      idle-animate: true
      phantom: true
      visible: false

    UIItem
      id: itemPreview
      size: 32 32
      anchors.centerIn: parent
      virtual: true
      phantom: true
      visible: false

  Label
    id: cardDescription
    anchors.top: previewPanel.top
    anchors.left: previewPanel.right
    anchors.right: parent.right
    anchors.bottom: previewPanel.bottom
    margin-left: 4
    margin-right: 4
    font: $var-cip-main-font
    color: $var-text-cip-color
    text-align: topLeft
    text-wrap: true

  HorizontalSeparator
    id: cardSeparator
    anchors.top: previewPanel.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    margin-top: 8
    margin-right: 10

  Button
    id: buyButton
    !text: tr('Buy')
    size: 66 20
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-bottom: 5
    color: $var-text-cip-color-white

    $disabled:
      color: $var-text-cip-color
      phantom: true

  Button
    id: boughtButton
    !text: tr('Bought')
    size: 66 20
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-bottom: 5
    visible: false
    disabled: true
    phantom: true
    color: $var-text-cip-color

    $disabled:
      color: $var-cip-inactive-color

  BattlePassShopInfoPanel
    id: pricePanel
    anchors.verticalCenter: buyButton.verticalCenter
    anchors.left: buyButton.right

  UIWidget
    id: typeBackdrop
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    margin-bottom: 0
    margin-right: -2
    phantom: true

BattlePassShopPanel < Panel
  anchors.fill: parent

  Panel
    id: battlePassShopHeader
    height: 42
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right

    Label
      id: battlePassShopTitle
      !text: tr('Battle Pass Shop')
      anchors.top: parent.top
      anchors.left: parent.left
      margin-top: 5
      margin-left: 8
      font: verdana-11px-rounded
      color: #c0c0c0
      text-auto-resize: true

    Label
      id: battlePassShopStatus
      !text: tr('Complete Battle Pass level 80 to unlock shop points.')
      anchors.bottom: parent.bottom
      anchors.left: parent.left
      margin-left: 8
      margin-bottom: 5
      font: verdana-11px-rounded
      color: #888888
      text-auto-resize: true

  UIWidget
    id: battlePassShopFrame
    anchors.top: battlePassShopHeader.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    margin-top: 8
    image-source: /images/ui/2pixel_up_frame_borderimage
    image-border: 2
    padding: 10

    ScrollablePanel
      id: battlePassShopGrid
      anchors.top: parent.top
      anchors.left: parent.left
      anchors.right: battlePassShopScrollBar.left
      anchors.bottom: parent.bottom
      vertical-scrollbar: battlePassShopScrollBar
      image-source: /images/ui/background_dark
      image-repeated: true
      padding-top: 10
      padding-left: 15
      padding-bottom: 10
      layout:
        type: grid
        cell-size: 295 144
        cell-spacing: 12
        flow: true

    VerticalScrollBar
      id: battlePassShopScrollBar
      anchors.top: parent.top
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      step: 48
      pixels-scroll: true

// MAIN WINDOW
NewHeadlessWindow
  id: battlePassWindow
  anchors.horizontalCenter: parent.horizontalCenter
  size: 1000 595
  @onEscape: modules.game_battlepass.BattlePass.hide()
  UIWidget
    size: 145 56
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: -33
    image-source: /images/game/tutorial/backdrop_crestr
    phantom: true
  Panel
    id: mainPanel
    anchors.fill: parent
    margin: 15 13 17 13
    Panel
      id: optionsTabBar
      height: 36
      image-source: /images/game/destiny_wheel/menuBg
      image-border: 1
      anchors.top: parent.top
      anchors.left: parent.left
      anchors.right: parent.right
      margin-top: 12
      BattlePassTabButton
        id: challengesMenu
        anchors.top: parent.top
        anchors.left: parent.left
        size: 322 34
        margin-left: 1
        margin-top: 1
        @onClick: modules.game_battlepass.BattlePass.loadMenu('challengesMenu')

      BattlePassTabButton
        id: rewardsMenu
        anchors.top: parent.top
        anchors.left: prev.right
        size: 322 34
        margin-left: 1
        margin-top: 1
        @onClick: modules.game_battlepass.BattlePass.loadMenu('rewardsMenu')

      BattlePassTabButton
        id: shopMenu
        anchors.top: parent.top
        anchors.left: prev.right
        anchors.right: parent.right
        margin-left: 1
        margin-right: 1
        margin-top: 1
        @onClick: modules.game_battlepass.BattlePass.loadMenu('shopMenu')

    Panel
      id: contentPanel
      anchors.top: optionsTabBar.bottom
      anchors.left: parent.left
      anchors.right: parent.right
      anchors.bottom: separator.top
      margin-top: 12
      margin-bottom: 8
      MissionPanel
        id: missionPanel
        visible: true
      ProgressPanel
        id: progressPanel
        visible: false
      BattlePassShopPanel
        id: battlePassShopPanel
        visible: false

    HorizontalSeparator
      id: separator
      anchors.bottom: next.top
      anchors.left: parent.left
      anchors.right: parent.right
      margin-bottom: 10
    Button
      id: close
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      !text: tr('Close')
      size: 43 20
      @onClick: modules.game_battlepass.BattlePass.hide()

    Button
      id: bPassWiki
      size: 80 20
      image-source: /images/ui/buttons-blue
      image-border: 2
      anchors.bottom: parent.bottom
      anchors.right: prev.left
      margin-right: 9
      !text: tr('Battle Pass Wiki')
      @onClick: g_platform.openUrl(BATTLEPASS_WIKI_URL)

    Button
      id: getVipPassTicket
      size: 130 20
      image-source: /images/ui/buttons-blue
      image-border: 2
      anchors.bottom: parent.bottom
      anchors.right: prev.left
      margin-right: 9
      !text: tr('Get Deluxe Battle Pass')
      @onClick: modules.game_battlepass.BattlePass.redirectToStore()
      UIWidget
        id: getVipIcon
        size: 16 16
        anchors.top: parent.top
        anchors.left: parent.left
        margin-left: -10
        margin-top: -10
        phantom: true
        image-source: /images/game/premium/icon-banner-premium-16x16
    UIWidget
      id: getVipPassTicketBorder
      size: 133 22
      anchors.top: prev.top
      anchors.left: prev.left
      margin-left: -1
      margin-top: -1
      phantom: true
      image-source: /images/store/rectangle-highlight

    Panel
      id: rCoinPanel
      size: 130 20
      anchors.bottom: parent.bottom
      anchors.left: parent.left
      image-source: /images/ui/progress
      image-border: 7
      Panel
        image-source: /images/store/icon-goldcoin
        anchors.right: parent.right
        anchors.top: parent.top
        margin-top: 6
        margin-right: 3
      UIWidget
        id: rCoins
        !text: tr('0')
        anchors.top: parent.top
        anchors.right: prev.left
        margin-right: 5
        margin-top: 3
        text-auto-resize: true
        color: #c0c0c0
        font: Verdana Bold-11px
        tooltip-font: Verdana Bold-11px

    BattlePassShopInfoPanel
      id: battlePassShopPointsPanel
      size: 130 20
      anchors.bottom: parent.bottom
      anchors.left: rCoinPanel.right
      margin-left: 8
      visible: false
